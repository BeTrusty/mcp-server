# Copy this file to .env.local for local development.
# On Vercel, set these as Environment Variables in the project dashboard.

# Port used only in standalone Bun mode (local dev / Railway).
# Vercel ignores this — it assigns its own port automatically.
PORT=3002

# Base URL of the BeTrusty app that exposes the pricing API.
# Local:      http://localhost:3000
# Production: https://app.betrusty.io
PRICING_API_BASE_URL=https://app.betrusty.io

# Runtime environment.
NODE_ENV=development
